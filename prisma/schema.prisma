generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int                    @id @default(autoincrement())
  nama         String                 @db.VarChar(100)
  email        String                 @unique @db.VarChar(100)
  password     String                 @db.VarChar(255)
  role         String                 @default("STAFF") 
  transactions InventoryTransaction[]
}

model Category {
  id            Int       @id @default(autoincrement())
  nama_kategori String    @db.VarChar(100)
  products      Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique @db.VarChar(50)
  nama_barang String   @db.VarChar(150)
  kategori_id Int
  total_stok  Int      @default(0)
  image_url   String?  @db.VarChar(255) 
  
  category     Category               @relation(fields: [kategori_id], references: [id])
  transactions InventoryTransaction[]
}

model InventoryTransaction {
  id             Int      @id @default(autoincrement())
  produk_id      Int
  user_id        Int
  tipe_transaksi String   @db.VarChar(20) 
  jumlah         Int
  keterangan     String?  @db.Text
  tanggal        DateTime @default(now())

  product Product @relation(fields: [produk_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])
}